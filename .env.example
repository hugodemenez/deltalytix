# Database Configuration
DATABASE_URL="postgresql://username:password@host:port/database?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://username:password@host:port/database"

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# PostHog analytics (EU Cloud)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=your_posthog_project_token_here
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Local dashboard auth bypass (development/self-host only — never enable in production)
# LOCAL_DASHBOARD_AUTH_BYPASS=true
# NEXT_PUBLIC_LOCAL_DASHBOARD_AUTH_BYPASS=true
# LOCAL_DASHBOARD_USER_ID=local-dashboard-user
# NEXT_PUBLIC_LOCAL_DASHBOARD_USER_ID=local-dashboard-user
# LOCAL_DASHBOARD_USER_EMAIL=local-dashboard@deltalytix.local
# NEXT_PUBLIC_LOCAL_DASHBOARD_USER_EMAIL=local-dashboard@deltalytix.local
# LOCAL_DASHBOARD_AUTH_BYPASS_ALLOW_PRODUCTION=1

# Discord Configuration
DISCORD_SECRET=your_discord_secret_here
DISCORD_ID=your_discord_id_here
REDIRECT_URL='http://localhost:3000/api/auth/callback'

# Security
ENCRYPTION_KEY=your_encryption_key_here

# Email Service
RESEND_API_KEY=your_resend_api_key_here

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here

# Optional: Jina Reader API key for Investing.com calendar cron
# (raises rate limits for https://r.jina.ai/ fetches of sslecal2.investing.com)
# JINA_API_KEY=your_jina_api_key_here

# Public URLs
NEXT_PUBLIC_DISCORD_INVITATION="https://discord.gg/your_invitation_link"
NEXT_PUBLIC_REPO_OWNER="your_github_username"
NEXT_PUBLIC_REPO_NAME="your_repo_name"

# Support Emails (from address must use the Resend-verified eu.updates.deltalytix.app domain)
SUPPORT_TEAM_EMAIL='support-team@example.com'
SUPPORT_EMAIL='support@eu.updates.deltalytix.app'

# Tutorial Videos
NEXT_PUBLIC_RITHMIC_PERFORMANCE_TUTORIAL_VIDEO='your_video_url_here'
NEXT_PUBLIC_RITHMIC_ORDER_TUTORIAL_VIDEO='your_video_url_here'
NEXT_PUBLIC_NINJATRADER_PERFORMANCE_TUTORIAL_VIDEO='your_video_url_here'

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY='your_stripe_publishable_key_here'
STRIPE_SECRET_KEY='your_stripe_secret_key_here'
STRIPE_WEBHOOK_SECRET='your_stripe_webhook_secret_here'

# DxFeed Configuration
DXFEED_AUTH_URL='https://authdxfeed.volumetricatrading.com/api/auth/token'
DXFEED_PLATFORM_KEY='your_dxfeed_platform_key_here'
# Prop firm id for debug scripts (see lib/dxfeed-propfirms.ts)
# DXFEED_PROP_FIRM_ID=miltraders
# 0=Production, 1=Staging/demo (defaults to 0 in production, 1 otherwise)
# DXFEED_ENVIRONMENT=0
# Hours until a DxFeed report token is treated as expired when the API does not send JWT exp (default 12)
# DXFEED_TOKEN_TTL_HOURS=12
