# ============================================================
# DELTALYTIX — локальный .env.local для разработки
# Скопируй этот файл: cp .env.local.example .env.local
# и заполни значения ниже
# ============================================================

# --- БАЗА ДАННЫХ (локальный Docker PostgreSQL) ---------------
# Для docker-compose.dev.yml:
DATABASE_URL="postgresql://devuser:devpass@localhost:5432/deltalytix_dev?schema=public"
DIRECT_URL="postgresql://devuser:devpass@localhost:5432/deltalytix_dev"

# Для Supabase (альтернатива Docker):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# --- SUPABASE ------------------------------------------------
# Создай проект на https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- OPENAI --------------------------------------------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# --- DISCORD OAUTH (можно пропустить для локальной разработки)
# https://discord.com/developers/applications → New Application → OAuth2
DISCORD_ID=your-discord-client-id
DISCORD_SECRET=your-discord-client-secret
REDIRECT_URL=http://localhost:3000/api/auth/callback

# --- БЕЗОПАСНОСТЬ --------------------------------------------
# Сгенерируй: openssl rand -hex 32
ENCRYPTION_KEY=your-32-char-hex-encryption-key

# --- EMAIL (необязательно для разработки) --------------------
# https://resend.com → API Keys
RESEND_API_KEY=re_your-key-here
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_TEAM_EMAIL=team@yourdomain.com

# --- STRIPE (необязательно для разработки) -------------------
# https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# --- GITHUB (для отображения changelog) ----------------------
GITHUB_TOKEN=ghp_your-token
NEXT_PUBLIC_REPO_OWNER=Bagirov24
NEXT_PUBLIC_REPO_NAME=deltalytix

# --- ПУБЛИЧНЫЕ ССЫЛКИ ----------------------------------------
NEXT_PUBLIC_DISCORD_INVITATION=https://discord.gg/your-invite

# --- TUTORIAL VIDEOS (можно оставить пустыми) ----------------
NEXT_PUBLIC_RITHMIC_PERFORMANCE_TUTORIAL_VIDEO=
NEXT_PUBLIC_RITHMIC_ORDER_TUTORIAL_VIDEO=
NEXT_PUBLIC_NINJATRADER_PERFORMANCE_TUTORIAL_VIDEO=

# --- DXFEED (опционально) ------------------------------------
DXFEED_AUTH_URL=https://authdxfeed.volumetricatrading.com/api/auth/token
DXFEED_PLATFORM_KEY=
