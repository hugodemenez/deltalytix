{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "deltalytix.app"
        }
      ],
      "destination": "https://www.deltalytix.app/en",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/investing?lang=fr&db=true",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron/investing?lang=en&db=true",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron/renewal-notice",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/renew-tradovate-token",
      "schedule": "*/10 * * * *"
    }
  ]
}